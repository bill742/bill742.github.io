{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "css.customData": [".vscode/css-custom-data.json"],
  "css.validate": true,
  "biome.enabled": false,
  "cSpell.words": ["billdean", "eightbit"]
}
